---
import LocalizedPage from "../../components/LocalizedPage.astro";
import { staticLocalePaths, type RouteKey } from "../../i18n/routes";

export function getStaticPaths() {
  return staticLocalePaths("tr").map(({ key, path }) => ({ params: { path: path === "/tr/" ? undefined : path.slice(4, -1) }, props: { routeKey: key } }));
}

interface Props { routeKey: RouteKey; }
const { routeKey } = Astro.props;
---
<LocalizedPage locale="tr" routeKey={routeKey} />
