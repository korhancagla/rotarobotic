---
import Icon from "./Icon.astro";
import SubpageFooter from "./SubpageFooter.astro";
import SubpageHeader from "./SubpageHeader.astro";
import SubpageMenu from "./SubpageMenu.astro";
import type { Locale } from "../i18n/config";
import { routePath } from "../i18n/routes";
import { localizeDeep, t } from "../i18n/translate";

interface Props {
  locale: Locale;
  variant?: "technologies" | "contact" | "expertise";
}

const { locale, variant = "technologies" } = Astro.props;
const isContact = variant === "contact";
const isExpertise = variant === "expertise";
const en = locale === "en";

interface ExpertiseItem {
  number: string;
  category: string;
  title: string;
  description: string;
  image: string;
  imagePosition: string;
  href?: string;
}

const technologies = [
  { number: "01", category: "Kaynak", title: "Punta Kaynak Sistemleri", description: "Yüksek tekrarlanabilirlik ve hassas proses kontrolü için entegre robotik kaynak hücreleri.", image: "/media/technologies/welding/image-01.webp", imagePosition: "center", href: "/teknolojiler/kaynak-teknolojileri/" },
  { number: "02", category: "Kaynak", title: "Gazaltı Kaynak Sistemleri", description: "Farklı parça geometrilerine uyum sağlayan esnek ve güvenilir otomasyon çözümleri.", image: "/media/technologies/welding/image-01.webp", imagePosition: "center", href: "/teknolojiler/kaynak-teknolojileri/" },
  { number: "03", category: "Taşıma", title: "Robotik Taşıma Sistemleri", description: "Üretim akışını kesintisiz, güvenli ve akıllı biçimde yöneten robotik transfer sistemleri.", image: "/media/technologies/material-handling/cover.webp", imagePosition: "center", href: "/teknolojiler/tasima-sistemleri/" },
  { number: "04", category: "Taşıma", title: "Paletleme Sistemleri", description: "Yüksek kapasitede, stabil ve izlenebilir paletleme süreçleri için çevik hücre tasarımları.", image: "/media/technologies/material-handling/cover.webp", imagePosition: "center", href: "/teknolojiler/tasima-sistemleri/" },
  { number: "05", category: "Taşıma", title: "Konveyör Sistemleri", description: "Hatlar arasında kontrollü ürün transferi sağlayan modüler konveyör altyapıları.", image: "/media/technologies/material-handling/cover.webp", imagePosition: "center 68%", href: "/teknolojiler/tasima-sistemleri/" },
  { number: "06", category: "Montaj", title: "Montaj Sistemleri", description: "Hassas montaj süreçlerini ölçüm, kontrol ve robotik otomasyonla bir araya getiren çözümler.", image: "/media/technologies/assembly/image-01.webp", imagePosition: "center", href: "/teknolojiler/montaj-sistemleri/" },
  { number: "07", category: "Dozaj", title: "Mastikleme ve Dozajlama", description: "Doğru hacim, doğru iz ve sürekli kalite için kontrollü uygulama sistemleri.", image: "/media/technologies/dispensing/cover.webp", imagePosition: "center", href: "/teknolojiler/mastikleme-dozajlama-sistemleri/" },
  { number: "08", category: "Robotik", title: "İşbirlikçi Robotlu Sistemler", description: "İnsan ve robotun aynı üretim alanında güvenle birlikte çalışmasını sağlayan esnek çözümler.", image: "/media/technologies/collaborative-robots/image-01.webp", imagePosition: "center", href: "/teknolojiler/isbirlikci-robotlu-sistemler/" },
];

const expertiseItems: ExpertiseItem[] = [
  { number: "01", category: "Proses", title: "Proses Tasarım ve Simülasyon", description: "Üretim akışını, çevrim süresini ve robot erişimlerini daha yatırım başlamadan doğrulayan mühendislik çalışmaları.", image: "/media/expertise/process-design/image-01.webp", imagePosition: "center", href: "/uzmanliklar/proses-tasarim-ve-simulasyon/" },
  { number: "02", category: "Tasarım", title: "Mekanik Tasarım", description: "Dayanım, erişilebilirlik, bakım kolaylığı ve üretilebilirliği birlikte ele alan detaylı sistem tasarımı.", image: "/media/expertise/mechanical-design/image-01.webp", imagePosition: "center", href: "/uzmanliklar/mekanik-tasarim/" },
  { number: "03", category: "Kalite", title: "3D Ölçüm ve Kalite Kontrol", description: "Parça ve sistem geometrilerini hassas ölçüm, karşılaştırma ve raporlama yöntemleriyle doğrulayan kalite kontrol çalışmaları.", image: "/media/expertise/measurement/image-01.webp", imagePosition: "center", href: "/uzmanliklar/3d-olcum-ve-kalite-kontrol/" },
  { number: "04", category: "İmalat", title: "Talaşlı İmalat", description: "Karmaşık parçaları hassas toleranslar, tekrarlanabilir kalite ve üretim ihtiyaçlarına uygun yöntemlerle hayata geçiren imalat çözümleri.", image: "/media/expertise/machining/image-01.webp", imagePosition: "center", href: "/uzmanliklar/talasli-imalat/" },
  { number: "05", category: "İmalat", title: "Mekanik – Elektrik İmalat", description: "Tasarım verilerini sahada çalışan, güvenli ve sürdürülebilir ekipmanlara dönüştüren kontrollü imalat süreçleri.", image: "/media/expertise/mechanic-electric/image-01.webp", imagePosition: "center", href: "/uzmanliklar/mekanik-elektrik-imalat/" },
  { number: "06", category: "Elektrik", title: "Elektrik Projelendirme", description: "Güç dağıtımı, pano, güvenlik ve saha bağlantılarını standartlara uygun biçimde bütünleştiren projelendirme.", image: "/media/expertise/electric-design/image-01.webp", imagePosition: "center", href: "/uzmanliklar/elektrik-projelendirme/" },
  { number: "07", category: "Otomasyon", title: "Otomasyon Yazılımı", description: "Üretim senaryolarını izlenebilir, kararlı ve kullanıcı dostu kontrol yazılımlarına dönüştüren çözümler.", image: "/media/expertise/automation-software/image-01.webp", imagePosition: "center", href: "/uzmanliklar/otomasyon-yazilim/" },
  { number: "08", category: "Robotik", title: "Robot Yazılımı ve Offline Programlama", description: "Robot yollarını, çevrim sürelerini ve proses davranışlarını dijital ortamda hazırlayan uzman programlama hizmeti.", image: "/media/expertise/robot-software/image-01.webp", imagePosition: "center", href: "/uzmanliklar/robot-yazilimi-ve-offline-programlama/" },
  { number: "09", category: "Saha", title: "Sistem Kurulum ve Devreye Alma", description: "Kurulumdan testlere, operatör eğitiminden üretim kabulüne kadar sahadaki tüm geçişi yöneten mühendislik desteği.", image: "/media/expertise/commissioning/image-01.webp", imagePosition: "center", href: "/uzmanliklar/sistem-kurulum-ve-devreye-alma/" },
];
const localizedTechnologies = localizeDeep(technologies, locale);
const localizedExpertiseItems = localizeDeep(expertiseItems, locale);

---

<div class:list={["technologies-page", { "technologies-page--contact": isContact, "technologies-page--expertise": isExpertise }]}>
  <div class="technologies-page__beams" aria-hidden="true"><i></i><i></i><i></i></div>

  <SubpageHeader locale={locale} pageName={isContact ? t(locale, "İletişim") : isExpertise ? t(locale, "Uzmanlıklarımız") : t(locale, "Teknolojilerimiz")} />
  <SubpageMenu locale={locale} />

  <main>
    <section class="technologies-hero">
      <div class="technologies-hero__copy">
        {isContact ? (
          <><h1><span>{en ? "Let’s" : "Birlikte"}</span> <span class="technologies-hero__accent">{en ? "engineer together." : "tasarlayalım."}</span></h1><p>{en ? "Contact our team to discuss your project, production goals and the engineering support you need." : "Projenizi, üretim hedeflerinizi ve ihtiyaç duyduğunuz mühendislik desteğini konuşmak için ekibimize ulaşın."}</p></>
        ) : isExpertise ? (
          <><h1><span>{en ? "From concept to production" : "Fikirden üretime"}</span> <span class="technologies-hero__accent">{en ? "end-to-end engineering." : "uçtan uca mühendislik."}</span></h1><p>{en ? "We manage the complete engineering lifecycle of robotic systems under one roof, from simulation and design to manufacturing, software and commissioning." : "Simülasyondan tasarıma, imalattan yazılıma ve devreye almaya kadar robotik sistemlerin tüm mühendislik sürecini tek çatı altında yönetiyoruz."}</p></>
        ) : (
          <><h1><span>{en ? "Intelligent systems" : "Üretimi dönüştüren"}</span> <span class="technologies-hero__accent">{en ? "transforming production." : "akıllı sistemler."}</span></h1><p>{en ? "Explore robotic production technologies engineered for welding, material handling, assembly and dispensing applications." : "Kaynak, taşıma, montaj ve dozajlama uygulamalarında ihtiyaca göre tasarlanan robotik üretim teknolojilerini keşfedin."}</p></>
        )}
      </div>
      {!isContact && <div class="technologies-hero__photo" aria-hidden="true"></div>}
      <div class:list={["technologies-hero__visual", { "technologies-hero__visual--contact": isContact }]} aria-hidden="true"><span></span><span></span><span></span>{isContact ? <div class="contact-hero__pin"><b>R</b><i></i></div> : <img src="/media/corporate/about-cover.webp" width="1254" height="1254" alt="" fetchpriority="high" />}</div>
      {isContact ? (
        <div class="technologies-hero__stats" aria-label={en ? "Contact page summary" : "İletişim sayfası özeti"}><span><strong>01</strong><small>{en ? "Istanbul Office" : "İstanbul Ofisi"}</small></span><span><strong>03</strong><small>{en ? "Contact Channels" : "İletişim Kanalı"}</small></span><span><strong>20+</strong><small>{t(locale, "Yıllık Deneyim")}</small></span></div>
      ) : isExpertise ? (
        <div class="technologies-hero__stats" aria-label={en ? "Expertise page summary" : "Uzmanlık sayfası özeti"}><span><strong>{String(localizedExpertiseItems.length).padStart(2,"0")}</strong><small>{t(locale, "Uzmanlık Alanı")}</small></span><span><strong>04</strong><small>{t(locale, "Temel Disiplin")}</small></span><span><strong>20+</strong><small>{t(locale, "Yıllık Deneyim")}</small></span></div>
      ) : (
        <div class="technologies-hero__stats" aria-label={en ? "Technologies page summary" : "Teknoloji sayfası özeti"}><span><strong>{String(localizedTechnologies.length).padStart(2,"0")}</strong><small>{t(locale, "Teknoloji Alanı")}</small></span><span><strong>05</strong><small>{t(locale, "Üretim Disiplini")}</small></span><span><strong>20+</strong><small>{t(locale, "Yıllık Deneyim")}</small></span></div>
      )}
    </section>

    {isContact ? (
      <>
        <section class="contact-library">
          <div class="technologies-section-heading technologies-reveal" data-technologies-reveal><div><p class="technologies-eyebrow">{en ? "Contact Center" : "İletişim Merkezi"}</p><h2>{en ? "Let’s Discuss Your Project." : "Projenizi konuşalım."}</h2><p class="technologies-section-heading__description">{en ? "Connect with the right engineering team through the channel that works best for you." : "Doğru mühendislik ekibiyle hızlıca buluşun; size en uygun kanaldan iletişime geçin."}</p></div></div>
          <div class="contact-details technologies-reveal" data-technologies-reveal>
            <a href="https://wa.me/905387788118" target="_blank" rel="noopener noreferrer"><span><Icon name="whatsapp" /></span><small>WhatsApp</small><strong>+90 538 778 81 18</strong></a>
            <a href="mailto:info@rotarobotik.com"><span><Icon name="envelope" /></span><small>{en ? "Email" : "E-posta"}</small><strong>info@rotarobotik.com</strong></a>
            <div><span><Icon name="location" /></span><small>{en ? "Address" : "Adres"}</small><strong>Yarış Çıkmazı Sokak No:1<br />{en ? "Independent Unit No:347, İSTİM Tuzla / Istanbul" : "Bağımsız Bölüm No:347, İSTİM Tuzla / İstanbul"}</strong></div>
          </div>
          <div class="contact-workspace">
            <form id="contact-form-page" class="contact-page-form technologies-reveal" method="post" data-technologies-reveal data-emailjs-form>
              <label class="contact-page-form__trap" aria-hidden="true"><span>{en ? "Website" : "Web sitesi"}</span><input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
              <input type="hidden" name="language" value={locale} />
              <div class="contact-page-form__heading"><p class="technologies-eyebrow">{en ? "Send a Message" : "Mesaj Gönderin"}</p><h3>{en ? "Let Us Get Back to You." : "Size dönüş yapalım."}</h3></div>
              <div class="contact-page-form__row"><label><span>{t(locale,"Adınız")}</span><input type="text" name="name" minlength="2" maxlength="80" autocomplete="name" required /></label><label><span>{t(locale,"Telefonunuz")}</span><input type="tel" name="phone" minlength="7" maxlength="24" autocomplete="tel" required /></label></div>
              <label><span>{t(locale,"E-posta adresiniz")}</span><input type="email" name="email" maxlength="120" autocomplete="email" required /></label>
              <label><span>{t(locale,"Mesajınız")}</span><textarea name="message" rows="5" minlength="10" maxlength="1200" required></textarea></label>
              <div class="contact-page-form__actions"><button type="submit"><span>{t(locale,"Gönder")}</span><i aria-hidden="true">→</i></button><p data-contact-page-status aria-live="polite" role="status"></p></div>
            </form>
            <div class="contact-page-map technologies-reveal" data-technologies-reveal><div data-contact-page-map aria-label={en ? "Map of the Rota Robotik İSTİM Tuzla office" : "Rota Robotik İSTİM Tuzla ofisi haritası"}></div><a href="https://www.google.com/maps/search/?api=1&query=Yar%C4%B1%C5%9F%20%C3%87%C4%B1kmaz%C4%B1%20Sokak%20No%3A1%20Ba%C4%9F%C4%B1ms%C4%B1z%20B%C3%B6l%C3%BCm%20No%3A347%20%C4%B0ST%C4%B0M%20Tuzla%20%C4%B0stanbul" target="_blank" rel="noopener noreferrer">{en ? "Get Directions" : "Haritada yol tarifi alın"} <i aria-hidden="true">→</i></a></div>
          </div>
        </section>
        <section class="contact-social technologies-reveal" data-technologies-reveal><p class="technologies-eyebrow">{en ? "Social Channels" : "Sosyal Kanallar"}</p><h2>{en ? "Connect with Us." : "Bizi takip edin."}</h2><div><a href="https://www.linkedin.com/company/rota-robotik-sistemler/" target="_blank" rel="noopener noreferrer"><Icon name="linkedin" /><span>LinkedIn</span><i>→</i></a><a href="https://wa.me/905387788118" target="_blank" rel="noopener noreferrer"><Icon name="whatsapp" /><span>WhatsApp</span><i>→</i></a></div></section>
      </>
    ) : isExpertise ? (
      <>
        <section class="technologies-library expertise-library"><div class="technologies-section-heading technologies-reveal" data-technologies-reveal><div><p class="technologies-eyebrow">{t(locale,"Mühendislik Yetkinlikleri")}</p><h2>{t(locale,"Tüm uzmanlıklarımız.")}</h2><p class="technologies-section-heading__description">{en ? "We manage every stage from initial concept through serial production with the same engineering discipline." : "Fikir aşamasından seri üretime kadar her adımı aynı mühendislik disipliniyle yönetiyoruz."}</p></div></div><div class="technologies-grid expertise-grid">{localizedExpertiseItems.map((item) => <a class="technology-card expertise-card technologies-reveal" data-technologies-reveal id={`uzmanlik-${item.number}`} href={item.href ?? routePath("contact",locale)} aria-label={en ? `View ${item.title} details` : `${item.title} detaylarını inceleyin`}><div class="technology-card__image"><img src={item.image} style={`object-position: ${item.imagePosition};`} width="1254" height="1254" alt={en ? `${item.title} engineering application` : `${item.title} mühendislik uygulaması`} loading="lazy" decoding="async" /><span>{item.number}</span></div><div class="technology-card__copy"><p>{item.category}</p><h3>{item.title}</h3><p>{item.description}</p><span class="technology-card__action">{item.href ? t(locale,"Detayları inceleyin") : t(locale,"Projenizi değerlendirelim")} <i aria-hidden="true">→</i></span></div></a>)}</div></section>
        <section class="technologies-cta technologies-reveal" data-technologies-reveal><p class="technologies-eyebrow">{t(locale,"Tek Ekip, Uçtan Uca Sorumluluk")}</p><h2>{t(locale,"Fikrinizi çalışan bir sisteme dönüştürelim.")}</h2><p>{en ? "Let’s analyze your requirements and manage design, software, manufacturing and commissioning under one engineering organization." : "İhtiyacınızı birlikte analiz edelim; tasarım, yazılım, imalat ve devreye alma süreçlerini tek bir mühendislik çatısı altında yönetelim."}</p><a href={routePath("contact",locale)}><span>{t(locale,"Projenizi Konuşalım")}</span><i aria-hidden="true">→</i></a></section>
      </>
    ) : (
      <>
        <section class="technologies-library"><div class="technologies-section-heading technologies-reveal" data-technologies-reveal><div><p class="technologies-eyebrow">{t(locale,"Teknoloji Kütüphanesi")}</p><h2>{t(locale,"Tüm teknolojilerimiz.")}</h2><p class="technologies-section-heading__description">{en ? "Integrated systems that evaluate process, available space and performance targets for every production requirement." : "Her üretim ihtiyacı için süreci, alanı ve performans hedefini birlikte değerlendiren entegre sistemler."}</p></div></div><div class="technologies-grid">{localizedTechnologies.map((technology) => <a class="technology-card technologies-reveal" data-technologies-reveal id={technology.number} href={technology.href ?? routePath("contact",locale)} aria-label={en ? `View ${technology.title} details` : `${technology.title} detaylarını inceleyin`}><div class="technology-card__image"><img src={technology.image} style={`object-position: ${technology.imagePosition};`} width="1254" height="1254" alt={en ? `${technology.title} robotic technology application` : `${technology.title} robotik teknoloji uygulaması`} loading="lazy" decoding="async" /><span>{technology.number}</span></div><div class="technology-card__copy"><p>{technology.category}</p><h3>{technology.title}</h3><p>{technology.description}</p><span class="technology-card__action">{t(locale,"Detayları inceleyin")} <i aria-hidden="true">→</i></span></div></a>)}</div></section>
        <section class="technologies-cta technologies-reveal" data-technologies-reveal><p class="technologies-eyebrow">{t(locale,"Doğru Teknoloji, Doğru Sistem")}</p><h2>{t(locale,"Üretim hedefinizi birlikte tasarlayalım.")}</h2><p>{en ? "Let’s analyze your process and combine the right technology with the system architecture your production goals require." : "Prosesinizi birlikte analiz edelim, ihtiyaçlarınıza uygun teknolojiyi doğru sistem mimarisiyle buluşturalım."}</p><a href={routePath("contact",locale)}><span>{t(locale,"İletişime Geçin")}</span><i aria-hidden="true">→</i></a></section>
      </>
    )}
  </main>

  <SubpageFooter locale={locale} revealVariant="technologies" />
</div>

<script>
  const technologiesPage = document.querySelector<HTMLElement>(".technologies-page");
  const technologiesHero = document.querySelector<HTMLElement>(".technologies-hero");
  const contactPageMapElement = document.querySelector<HTMLElement>("[data-contact-page-map]");
  const contactPageStatus = document.querySelector<HTMLElement>("[data-contact-page-status]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const pageIsTurkish = document.documentElement.lang === "tr";

  let technologiesBeamFrame = 0;
  const updateTechnologiesBeam = () => {
    technologiesBeamFrame = 0;
    const beamStart = window.innerHeight * .16;
    const beamRange = Math.max(window.innerHeight * .68, 1);
    const beamProgress = Math.max(0, Math.min(1, (window.scrollY - beamStart) / beamRange));
    technologiesPage?.style.setProperty("--technologies-beam-opacity", beamProgress.toFixed(3));
  };
  const queueTechnologiesBeam = () => {
    if (technologiesBeamFrame) return;
    technologiesBeamFrame = window.requestAnimationFrame(updateTechnologiesBeam);
  };
  updateTechnologiesBeam();
  window.addEventListener("scroll", queueTechnologiesBeam, { passive: true });
  window.addEventListener("resize", queueTechnologiesBeam, { passive: true });

  const initializeContactPageMap = async () => {
    if (!contactPageMapElement || contactPageMapElement.dataset.ready) return;
    contactPageMapElement.dataset.ready = "loading";
    try {
      const L = await import("leaflet/dist/leaflet-src.esm.js");
      const rotaLocation: [number, number] = [40.8234, 29.3488];
      const map = L.map(contactPageMapElement, { attributionControl: true, zoomControl: false, scrollWheelZoom: false, zoomSnap: .25 }).setView(rotaLocation, 12.25);
      map.attributionControl.setPrefix(false);
      L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", { attribution: "&copy; OpenStreetMap contributors &copy; CARTO", maxZoom: 20, subdomains: "abcd" }).addTo(map);
      L.control.zoom({ position: "bottomleft", zoomInTitle: pageIsTurkish ? "Yakınlaştır" : "Zoom in", zoomOutTitle: pageIsTurkish ? "Uzaklaştır" : "Zoom out" }).addTo(map);
      const marker = L.divIcon({ className: "contact-page-marker", html: '<span aria-hidden="true"><b>R</b></span>', iconSize: [70,70], iconAnchor: [35,60] });
      L.marker(rotaLocation, { icon: marker, interactive: false }).addTo(map);
      contactPageMapElement.dataset.ready = "true";
      window.requestAnimationFrame(() => map.invalidateSize());
    } catch {
      delete contactPageMapElement.dataset.ready;
    }
  };

  if (contactPageMapElement) {
    if ("IntersectionObserver" in window) {
      const contactMapObserver = new IntersectionObserver((entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        contactMapObserver.disconnect();
        void initializeContactPageMap();
      }, { rootMargin: "320px" });
      contactMapObserver.observe(contactPageMapElement);
    } else void initializeContactPageMap();
  }

  if (contactPageStatus) {
    const currentUrl = new URL(window.location.href);
    const result = currentUrl.searchParams.get("contact");
    if (result === "success") { contactPageStatus.textContent = pageIsTurkish ? "Mesajınız gönderildi. Teşekkür ederiz." : "Your message has been sent. Thank you."; contactPageStatus.dataset.state = "success"; }
    if (result === "error") { contactPageStatus.textContent = pageIsTurkish ? "Mesaj gönderilemedi. Lütfen tekrar deneyin." : "Your message could not be sent. Please try again."; contactPageStatus.dataset.state = "error"; }
    if (result) { currentUrl.searchParams.delete("contact"); window.history.replaceState({}, "", `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`); }
  }

  const technologyRevealItems = Array.from(document.querySelectorAll<HTMLElement>("[data-technologies-reveal]"));
  if (reducedMotion || !("IntersectionObserver" in window)) {
    technologyRevealItems.forEach((item) => item.classList.add("technologies-reveal--visible"));
  } else {
    technologiesPage?.classList.add("technologies-page--enhanced");

    const technologiesRevealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        (entry.target as HTMLElement).classList.toggle("technologies-reveal--visible", entry.isIntersecting);
      });
    }, { rootMargin: "0px 0px -12%", threshold: .12 });
    technologyRevealItems.forEach((item) => technologiesRevealObserver.observe(item));

    if (technologiesHero) {
      const technologiesHeroObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          technologiesHero.classList.toggle("technologies-hero--in-view", entry.isIntersecting);
        });
      }, { rootMargin: "-10% 0px -10%", threshold: .12 });

      technologiesHero.classList.add("technologies-hero--in-view");
      technologiesHeroObserver.observe(technologiesHero);
      window.setTimeout(() => technologiesHero.classList.add("technologies-hero--motion-ready"), 1650);
    }
  }
</script>

<style>
