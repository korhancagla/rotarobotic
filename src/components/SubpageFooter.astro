---
import type { Locale } from "../i18n/config";
import { routePath } from "../i18n/routes";
interface Props { locale: Locale; revealVariant?: "references" | "technologies"; }
const { locale, revealVariant } = Astro.props;
const currentYear = new Date().getFullYear();
const en = locale === "en";
---

<footer
  class:list={["subpage-footer", { "references-reveal": revealVariant === "references", "technologies-reveal": revealVariant === "technologies" }]}
  data-references-reveal={revealVariant === "references" ? true : undefined}
  data-technologies-reveal={revealVariant === "technologies" ? true : undefined}
>
  <a href={routePath("home", locale)} aria-label={en ? "Rota Robotic homepage" : "Rota Robotik ana sayfa"}><img src={en ? "/media/brand/logo-en.svg" : "/media/brand/logo.svg"} width="363" height="180" alt={en ? "Rota Robotic Systems" : "Rota Robotik Sistemler"} /></a>
  <p>{en ? "All rights reserved" : "Tüm hakları saklıdır"} © {currentYear} Rota Robotik</p>
  <div><a href={routePath("about", locale)}>{en ? "Company" : "Kurumsal"}</a><a href={routePath("expertise", locale)}>{en ? "Expertise" : "Uzmanlıklar"}</a><a href={routePath("technologies", locale)}>{en ? "Technologies" : "Teknolojiler"}</a><a href={routePath("contact", locale)}>{en ? "Contact" : "İletişim"}</a></div>
</footer>

<style>
  .subpage-footer {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 50px;
    align-items: center;
    padding: 44px clamp(28px,6vw,110px) calc(44px + env(safe-area-inset-bottom,0px));
    border-top: 3px solid transparent;
    border-image: linear-gradient(90deg,var(--rota-blue),var(--rota-teal),var(--rota-green)) 1;
    background: #061827;
    color: rgba(255,255,255,.58);
  }
  .subpage-footer > a { display: block; width: 160px; filter: brightness(0) invert(1); }
  .subpage-footer img { display: block; width: 100%; height: auto; }
  .subpage-footer p { justify-self: center; margin: 0; font-size: var(--type-xs); text-align: center; white-space: nowrap; }
  .subpage-footer > div { display: flex; justify-self: end; gap: 20px; }
  .subpage-footer > div a { color: rgba(255,255,255,.62); font-size: var(--type-xs); text-decoration: none; }
  .subpage-footer > div a:hover, .subpage-footer > div a:focus-visible { color: #fff; }

  @media (max-width: 640px) {
    .subpage-footer { grid-template-columns: 1fr; grid-template-areas: "links" "logo" "copyright"; gap: 22px; justify-items: center; text-align: center; }
    .subpage-footer > a { grid-area: logo; width: auto; }
    .subpage-footer > a img { width: auto; height: 45px; }
    .subpage-footer > p { grid-area: copyright; font-size: 14px; }
    .subpage-footer > div { grid-area: links; flex-wrap: wrap; justify-content: center; }
    .subpage-footer > a, .subpage-footer > div, .subpage-footer > p { justify-self: center; }
  }
</style>
