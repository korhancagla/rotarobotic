  welding: { heroImage: "/media/technologies/welding/image-01.webp", galleryImages: technologyServiceGalleryImages("welding", "kaynak teknolojileri", 2) },
  "material-handling": { heroImage: "/media/technologies/material-handling/cover.webp" },
  assembly: { heroImage: "/media/technologies/assembly/image-01.webp", galleryImages: technologyServiceGalleryImages("assembly", "montaj sistemleri", 4) },
  dispensing: { heroImage: "/media/technologies/dispensing/cover.webp" },
  "collaborative-robots": { heroImage: "/media/technologies/collaborative-robots/image-01.webp", galleryImages: technologyServiceGalleryImages("collaborative-robots", "işbirlikçi robotlu sistemler", 2) },
} as const;

const basePageContent = servicePages[variant as keyof typeof servicePages] ?? detailPages[variant as keyof typeof detailPages] ?? detailPages.measurement;
const relocatedHeroImages: Record<string, string> = {
  "/media/engineering/process-design.webp": "/media/expertise/library/process-design.webp",
  "/media/engineering/mechanical-design.webp": "/media/expertise/library/mechanical-design.webp",
  "/media/engineering/mechanic-electric.webp": "/media/expertise/library/mechanic-electric.webp",
  "/media/engineering/electric-design.webp": "/media/expertise/library/electric-design.webp",
  "/media/engineering/automation-software.webp": "/media/expertise/library/automation-software.webp",
  "/media/engineering/offline-programming.webp": "/media/expertise/library/offline-programming.webp",
  "/media/engineering/commissioning.webp": "/media/expertise/library/commissioning.webp",
  "/media/technologies/arc-welding.webp": "/media/technologies/welding/legacy-arc-welding.webp",
  "/media/technologies/material-handling.webp": "/media/technologies/material-handling/cover.webp",
  "/media/technologies/assembly.webp": "/media/technologies/assembly/legacy-cover.webp",
  "/media/technologies/dispensing.webp": "/media/technologies/dispensing/cover.webp",
};
const normalizedBasePageContent = {
  ...basePageContent,
  heroImage: relocatedHeroImages[basePageContent.heroImage] ?? basePageContent.heroImage,
};
const pageContent = localizeDeep({
  ...normalizedBasePageContent,
  ...(expertisePageMedia[variant as keyof typeof expertisePageMedia] ?? {}),
  ...(technologyPageMedia[variant as keyof typeof technologyPageMedia] ?? {}),
}, locale);
const capabilities = pageContent.capabilities;
const systemTags = pageContent.systemTags;
const processSteps = pageContent.processSteps;
const applicationAreas = pageContent.applicationAreas;
const galleryImages = pageContent.galleryImages;
---

<div class="measurement-detail" data-measurement-detail>
  <SubpageHeader locale={locale} pageName={pageContent.pageName} />
  <SubpageMenu locale={locale} />

  <main>
    <section class="measurement-hero">
      <nav class="measurement-breadcrumb" aria-label={t(locale,"Sayfa yolu")}>
        <a href={routePath("home",locale)}>{en ? "Home" : "Ana Sayfa"}</a><i aria-hidden="true">/</i>{pageContent.parentName && <><a href={pageContent.parentHref}>{pageContent.parentName}</a><i aria-hidden="true">/</i></>}<span>{pageContent.pageName}</span>
      </nav>
      <div class="measurement-hero__copy">
        <h1>{pageContent.heroTitle} <span>{pageContent.heroAccent}</span></h1>
        <p class="measurement-hero__intro">{pageContent.heroIntro}</p>
      </div>
      <div class="measurement-hero__visual" aria-hidden="true">
        <img src={pageContent.heroImage} width={pageContent.heroImageWidth} height={pageContent.heroImageHeight} alt="" fetchpriority="high" />
      </div>
      <div class="measurement-hero__line" aria-hidden="true"></div>
    </section>

    <section class="measurement-overview">
      <div class="measurement-overview__copy measurement-reveal" data-measurement-reveal>
        <p class="measurement-eyebrow">{pageContent.eyebrow}</p>
        <h2>{pageContent.overviewTitle}</h2>
        <p>{pageContent.overviewText}</p>
      </div>
      <div class="measurement-gallery measurement-reveal" data-measurement-gallery data-measurement-reveal>
        <figure class="measurement-overview__visual">
          <button class="measurement-gallery__stage" type="button" aria-label={t(locale,"Fotoğrafı büyüt")} data-measurement-gallery-stage>
            {galleryImages.map((image, index) => (
              <img
                class:list={["measurement-gallery__image", { "measurement-gallery__image--active": index === 0 }]}
                src={image.src}
                width={image.width}
                height={image.height}
                alt={image.alt}
                loading="lazy"
                decoding="async"
                data-measurement-gallery-image
              />
            ))}
          </button>
        </figure>

        <div class="measurement-gallery__filmstrip" role="tablist" aria-label={pageContent.galleryLabel} style={`--measurement-gallery-count:${galleryImages.length}`}>
          {galleryImages.map((image, index) => (
            <button
              class:list={["measurement-gallery__thumb", { "measurement-gallery__thumb--active": index === 0 }]}
              type="button"
              role="tab"
              aria-selected={index === 0 ? "true" : "false"}
              aria-label={en ? `Image ${index + 1}` : `${index + 1}. fotoğraf`}
              data-measurement-gallery-thumb
            >
              <img src={image.src} width={image.width} height={image.height} alt="" loading="lazy" decoding="async" />
              <span>{String(index + 1).padStart(2, "0")}</span>
            </button>
          ))}
        </div>

        <div class="measurement-lightbox" role="dialog" aria-modal="true" aria-label={pageContent.galleryLabel} hidden data-measurement-lightbox>
          <button class="measurement-lightbox__close" type="button" aria-label={t(locale,"Galeriyi kapat")} data-measurement-lightbox-close>×</button>
          <button class="measurement-lightbox__control measurement-lightbox__control--prev" type="button" aria-label={t(locale,"Önceki fotoğraf")} data-measurement-lightbox-prev>←</button>
          <figure>
            <img src={galleryImages[0].src} width={galleryImages[0].width} height={galleryImages[0].height} alt={galleryImages[0].alt} data-measurement-lightbox-image />
          </figure>
          <button class="measurement-lightbox__control measurement-lightbox__control--next" type="button" aria-label={t(locale,"Sonraki fotoğraf")} data-measurement-lightbox-next>→</button>
        </div>
      </div>
    </section>

    <section class="measurement-capabilities">
      <div class="measurement-section-heading measurement-reveal" data-measurement-reveal>
        <p class="measurement-eyebrow">{pageContent.capabilitiesEyebrow}</p>
        <h2>{pageContent.capabilitiesTitle}</h2>
      </div>
      <div class="measurement-capabilities__grid">
        {capabilities.map((capability) => (
          <article class="measurement-capability measurement-reveal" data-measurement-reveal>
            <span>{capability.number}</span>
            <h3>{capability.title}</h3>
            <p>{capability.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="measurement-systems">
      <div class="measurement-reveal" data-measurement-reveal>
        <p class="measurement-eyebrow">{pageContent.systemsEyebrow}</p>
        <h2>{pageContent.systemsTitle}</h2>
      </div>
      <div class="measurement-systems__content measurement-reveal" data-measurement-reveal>
        <p>{pageContent.systemsText}</p>
        <div class="measurement-systems__tags" aria-label={pageContent.systemsTitle}>
          {systemTags.map((tag, index) => <span><i>{String(index + 1).padStart(2, "0")}</i>{tag}</span>)}
        </div>
      </div>
    </section>

    <section class="measurement-process">
      <div class="measurement-section-heading measurement-reveal" data-measurement-reveal>
        <p class="measurement-eyebrow">{pageContent.processEyebrow}</p>
        <h2>{pageContent.processTitle}</h2>
      </div>
      <ol class="measurement-process__steps">
        {processSteps.map((step) => (
          <li class="measurement-reveal" data-measurement-reveal>
            <span>{step.number}</span><i aria-hidden="true"></i><h3>{step.title}</h3><p>{step.description}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="measurement-applications">
      <div class="measurement-section-heading measurement-reveal" data-measurement-reveal>
        <p class="measurement-eyebrow">{pageContent.applicationsEyebrow}</p>
        <h2>{pageContent.applicationsTitle}</h2>
      </div>
      <ul class="measurement-applications__grid">
        {applicationAreas.map((area, index) => <li class="measurement-reveal" data-measurement-reveal><span>{String(index + 1).padStart(2, "0")}</span>{area}</li>)}
      </ul>
    </section>

    <a class="measurement-next measurement-reveal" href={pageContent.nextHref} data-measurement-reveal>
      <span><small>{pageContent.nextLabel}</small><strong>{pageContent.nextTitle}</strong></span><i aria-hidden="true">→</i>
    </a>
  </main>

  <SubpageFooter locale={locale} />
</div>

<script>
  const measurementDetail = document.querySelector<HTMLElement>("[data-measurement-detail]");
  const measurementHero = document.querySelector<HTMLElement>(".measurement-hero");
  const measurementRevealItems = Array.from(document.querySelectorAll<HTMLElement>("[data-measurement-reveal]"));
  const measurementReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!measurementReducedMotion && "IntersectionObserver" in window) {
    measurementDetail?.classList.add("measurement-detail--enhanced");
    let measurementLastScrollY = window.scrollY;
    let measurementScrollDirection: "up" | "down" = "down";
    let measurementScrollFrame = 0;

    const measurementUpdateHeroScroll = () => {
      const measurementHeroHeight = measurementHero?.offsetHeight || window.innerHeight;
      const measurementHeroProgress = Math.min(Math.max(window.scrollY / (measurementHeroHeight * .55), 0), 1);
      measurementHero?.style.setProperty("--measurement-hero-scroll", measurementHeroProgress.toFixed(3));
      measurementScrollFrame = 0;
    };

    window.addEventListener("scroll", () => {
      const measurementCurrentScrollY = window.scrollY;
      if (Math.abs(measurementCurrentScrollY - measurementLastScrollY) > 3) {
        measurementScrollDirection = measurementCurrentScrollY > measurementLastScrollY ? "down" : "up";
        measurementLastScrollY = measurementCurrentScrollY;
      }
      if (!measurementScrollFrame) measurementScrollFrame = window.requestAnimationFrame(measurementUpdateHeroScroll);
    }, { passive: true });
    measurementUpdateHeroScroll();

    const measurementObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const measurementItem = entry.target as HTMLElement;
        measurementItem.classList.toggle("measurement-reveal--from-top", measurementScrollDirection === "up");
        measurementItem.classList.toggle("measurement-reveal--visible", entry.isIntersecting);
      });
    }, { rootMargin: "0px 0px -10%", threshold: .1 });
    measurementRevealItems.forEach((item) => measurementObserver.observe(item));
  }

  const measurementGalleries = Array.from(document.querySelectorAll<HTMLElement>("[data-measurement-gallery]"));

  measurementGalleries.forEach((gallery) => {
    const galleryImages = Array.from(gallery.querySelectorAll<HTMLImageElement>("[data-measurement-gallery-image]"));
    const galleryThumbs = Array.from(gallery.querySelectorAll<HTMLButtonElement>("[data-measurement-gallery-thumb]"));
    const galleryFilmstrip = gallery.querySelector<HTMLElement>(".measurement-gallery__filmstrip");
    const galleryStage = gallery.querySelector<HTMLButtonElement>("[data-measurement-gallery-stage]");
    const galleryLightbox = gallery.querySelector<HTMLElement>("[data-measurement-lightbox]");
    const galleryLightboxImage = gallery.querySelector<HTMLImageElement>("[data-measurement-lightbox-image]");
    const galleryLightboxClose = gallery.querySelector<HTMLButtonElement>("[data-measurement-lightbox-close]");
    const galleryLightboxPrev = gallery.querySelector<HTMLButtonElement>("[data-measurement-lightbox-prev]");
    const galleryLightboxNext = gallery.querySelector<HTMLButtonElement>("[data-measurement-lightbox-next]");
    let galleryCurrentIndex = 0;
    let galleryAutoplay = 0;
    let galleryTouchStartX = 0;
    let galleryWasFocused: HTMLElement | null = null;
    let galleryIsVisible = true;

    if (galleryLightbox) document.body.append(galleryLightbox);

    const updateGalleryLightbox = () => {
      const activeImage = galleryImages[galleryCurrentIndex];
      if (galleryLightboxImage && activeImage) {
        galleryLightboxImage.src = activeImage.currentSrc || activeImage.src;
        galleryLightboxImage.alt = activeImage.alt;
      }
    };

    const showGalleryImage = (nextIndex: number) => {
      if (!galleryImages.length) return;
      galleryCurrentIndex = (nextIndex + galleryImages.length) % galleryImages.length;
      galleryImages.forEach((image, index) => image.classList.toggle("measurement-gallery__image--active", index === galleryCurrentIndex));
      galleryThumbs.forEach((thumb, index) => {
        const isActive = index === galleryCurrentIndex;
        thumb.classList.toggle("measurement-gallery__thumb--active", isActive);
        thumb.setAttribute("aria-selected", String(isActive));
        thumb.tabIndex = isActive ? 0 : -1;
      });
      const activeThumb = galleryThumbs[galleryCurrentIndex];
      if (galleryFilmstrip && activeThumb) {
        galleryFilmstrip.scrollTo({
          left: activeThumb.offsetLeft - (galleryFilmstrip.clientWidth - activeThumb.offsetWidth) / 2,
          behavior: measurementReducedMotion ? "auto" : "smooth",
        });
      }
      updateGalleryLightbox();
    };

    const stopGalleryAutoplay = () => window.clearInterval(galleryAutoplay);
    const startGalleryAutoplay = () => {
      stopGalleryAutoplay();
      if (measurementReducedMotion || galleryImages.length < 2 || !galleryIsVisible || document.hidden || (galleryLightbox && !galleryLightbox.hidden)) return;
      galleryAutoplay = window.setInterval(() => showGalleryImage(galleryCurrentIndex + 1), 4800);
    };

    const closeGalleryLightbox = () => {
      if (!galleryLightbox || galleryLightbox.hidden) return;
      galleryLightbox.hidden = true;
      document.body.classList.remove("measurement-lightbox-is-open");
      galleryWasFocused?.focus();
      startGalleryAutoplay();
    };

    const openGalleryLightbox = () => {
      if (!galleryLightbox || !window.matchMedia("(min-width: 981px)").matches) return;
      galleryWasFocused = document.activeElement as HTMLElement;
      updateGalleryLightbox();
      galleryLightbox.hidden = false;
      document.body.classList.add("measurement-lightbox-is-open");
      stopGalleryAutoplay();
      galleryLightboxClose?.focus();
    };

    galleryThumbs.forEach((thumb, index) => {
      thumb.addEventListener("click", () => {
        showGalleryImage(index);
        startGalleryAutoplay();
      });
    });

    galleryStage?.addEventListener("click", () => {
      if (window.matchMedia("(min-width: 981px)").matches) openGalleryLightbox();
      else {
        showGalleryImage(galleryCurrentIndex + 1);
        startGalleryAutoplay();
      }
    });
    galleryStage?.addEventListener("touchstart", (event) => { galleryTouchStartX = event.changedTouches[0]?.clientX || 0; }, { passive: true });
    galleryStage?.addEventListener("touchend", (event) => {
      const galleryTouchDistance = (event.changedTouches[0]?.clientX || 0) - galleryTouchStartX;
      if (Math.abs(galleryTouchDistance) < 45) return;
      showGalleryImage(galleryCurrentIndex + (galleryTouchDistance < 0 ? 1 : -1));
      startGalleryAutoplay();
    }, { passive: true });

    galleryLightboxClose?.addEventListener("click", closeGalleryLightbox);
    galleryLightboxPrev?.addEventListener("click", () => showGalleryImage(galleryCurrentIndex - 1));
    galleryLightboxNext?.addEventListener("click", () => showGalleryImage(galleryCurrentIndex + 1));
    galleryLightbox?.addEventListener("click", (event) => { if (event.target === galleryLightbox) closeGalleryLightbox(); });
    document.addEventListener("keydown", (event) => {
      if (!galleryLightbox || galleryLightbox.hidden) return;
      if (event.key === "Escape") closeGalleryLightbox();
      if (event.key === "ArrowLeft") showGalleryImage(galleryCurrentIndex - 1);
      if (event.key === "ArrowRight") showGalleryImage(galleryCurrentIndex + 1);
    });
    gallery.addEventListener("mouseenter", stopGalleryAutoplay);
    gallery.addEventListener("mouseleave", startGalleryAutoplay);
    gallery.addEventListener("focusin", stopGalleryAutoplay);
    gallery.addEventListener("focusout", (event) => {
      if (!gallery.contains(event.relatedTarget as Node) && (!galleryLightbox || galleryLightbox.hidden)) startGalleryAutoplay();
    });

    if ("IntersectionObserver" in window) {
      const galleryVisibilityObserver = new IntersectionObserver(([entry]) => {
        galleryIsVisible = Boolean(entry?.isIntersecting);
        if (galleryIsVisible) startGalleryAutoplay();
        else stopGalleryAutoplay();
      }, { threshold: .2 });
      galleryVisibilityObserver.observe(gallery);
    }

    document.addEventListener("visibilitychange", startGalleryAutoplay);
    showGalleryImage(0);
    startGalleryAutoplay();
  });
</script>

